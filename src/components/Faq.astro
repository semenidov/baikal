---
import { faq } from '../data/site';
---

<section id="faq" class="bg-[var(--color-fill)]/40 py-14 sm:py-20 lg:py-28">
  <div class="container-page max-w-3xl">
    <p class="eyebrow">{faq.eyebrow}</p>
    <h2 class="mt-3 text-3xl sm:text-4xl">{faq.title}</h2>

    <div class="mt-10 divide-y divide-[var(--color-line)] border-y border-[var(--color-line)]">
      {
        faq.items.map((item) => (
          <details class="group">
            <summary class="flex cursor-pointer list-none items-center justify-between gap-4 py-5 text-left text-lg font-medium">
              <span>{item.q}</span>
              <span class="shrink-0 text-[var(--color-accent)] transition-transform group-open:rotate-45">＋</span>
            </summary>
            <p class="pb-5 leading-relaxed text-[var(--color-muted)]">{item.a}</p>
          </details>
        ))
      }
    </div>
  </div>
</section>
