---
import { Image } from 'astro:assets';
import { reviews } from '../data/site';
import imgMikhail from '../assets/photos/review-mikhail.jpg';
import imgAnastasia from '../assets/photos/review-anastasia.jpg';
import imgMarina from '../assets/photos/review-marina.jpg';

const photos: Record<string, ImageMetadata> = {
  mikhail: imgMikhail,
  anastasia: imgAnastasia,
  marina: imgMarina,
};
---

<section class="py-20 sm:py-28">
  <div class="container-page">
    <p class="eyebrow">{reviews.eyebrow}</p>
    <h2 class="mt-3 max-w-2xl text-3xl sm:text-4xl">{reviews.title}</h2>
    <p class="mt-4 max-w-2xl text-[var(--color-muted)]">{reviews.subtitle}</p>

    <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        reviews.items.map((review) => (
          <figure class="flex h-full flex-col overflow-hidden rounded-2xl bg-[#17212b] shadow-[0_1px_2px_rgba(14,31,43,0.06),0_16px_32px_-18px_rgba(14,31,43,0.45)]">
            <Image
              src={photos[review.photo]}
              alt={`Отзыв от ${review.name} о туре с Егором`}
              class="w-full"
              widths={[400, 600, 800]}
              sizes="(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw"
            />
            <figcaption class="mt-auto flex items-center gap-2 border-t border-white/10 bg-[#1f2a36] px-4 py-3">
              <span class="h-1.5 w-1.5 rounded-full bg-[var(--color-cta)]" />
              <span class="text-sm font-medium text-white/90">{review.name}</span>
            </figcaption>
          </figure>
        ))
      }
    </div>
  </div>
</section>
