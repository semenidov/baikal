---
import { Image } from 'astro:assets';
import { reviews } from '../data/site';
import imgMikhail from '../assets/photos/review-mikhail.jpg';
import imgAnastasia from '../assets/photos/review-anastasia.jpg';
import imgMarina from '../assets/photos/review-marina.jpg';

const photos: Record<string, ImageMetadata> = {
  mikhail: imgMikhail,
  anastasia: imgAnastasia,
  marina: imgMarina,
};
---

<section class="py-20 sm:py-28">
  <div class="container-page">
    <p class="eyebrow">{reviews.eyebrow}</p>
    <h2 class="mt-3 max-w-2xl text-3xl sm:text-4xl">{reviews.title}</h2>
    <p class="mt-4 max-w-2xl text-[var(--color-muted)]">{reviews.subtitle}</p>

    <div class="mt-12 grid gap-6 md:grid-cols-3">
      {
        reviews.items.map((review) => (
          <figure class="overflow-hidden rounded-2xl border border-[var(--color-line)] bg-[var(--color-surface)] p-3">
            <Image
              src={photos[review.photo]}
              alt={`Отзыв от ${review.name} о туре с Егором`}
              class="w-full rounded-lg"
              widths={[400, 600, 800]}
              sizes="(min-width: 768px) 33vw, 100vw"
            />
          </figure>
        ))
      }
    </div>
  </div>
</section>
