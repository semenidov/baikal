---
import { Image } from 'astro:assets';
import { founders } from '../data/site';
import photoEgor from '../assets/photos/founder-egor.png';
import photoSergey from '../assets/photos/founder-sergey.jpg';

// Сопоставление site.ts person.photo -> реальный файл.
const photos: Record<string, ImageMetadata> = {
  guide: photoEgor,
  sergey: photoSergey,
};
// Точка фокуса кадра — оба фото не студийные, лица не по центру.
const focus: Record<string, string> = {
  guide: 'center 30%',
  sergey: 'center 22%',
};
---

<section id="about" class="py-20 sm:py-28">
  <div class="container-page">
    <p class="eyebrow">{founders.eyebrow}</p>
    <h2 class="mt-3 max-w-2xl text-3xl sm:text-4xl">{founders.title}</h2>
    <p class="mt-5 max-w-2xl text-lg leading-relaxed text-[var(--color-ink)]">{founders.lead}</p>

    <div class="mt-6 grid max-w-3xl gap-4 text-[var(--color-muted)] sm:text-[1.05rem]">
      {founders.story.map((p) => <p class="leading-relaxed">{p}</p>)}
    </div>

    <div class="mt-14 grid gap-6 md:grid-cols-2">
      {
        founders.people.map((person) => (
          <article class="flex flex-col overflow-hidden rounded-2xl border border-[var(--color-line)] bg-[var(--color-surface)]">
            <Image
              src={photos[person.photo]}
              alt={`${person.name} — ${person.role}`}
              class="aspect-[4/3] w-full object-cover"
              style={`object-position: ${focus[person.photo] ?? 'center'}`}
              widths={[400, 640, 800]}
              sizes="(min-width: 768px) 40vw, 100vw"
            />
            <div class="flex flex-1 flex-col p-6">
              <h3 class="text-xl">{person.name}</h3>
              <p class="mt-1 text-sm font-medium text-[var(--color-accent)]">{person.role}</p>
              <p class="mt-3 leading-relaxed text-[var(--color-muted)]">{person.note}</p>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
