---
import { site } from '../data/site';
const year = new Date().getFullYear();
---

<footer class="border-t border-[var(--color-line)] py-14">
  <div class="container-page grid gap-10 sm:grid-cols-2 lg:grid-cols-[1.4fr_1fr_1fr]">
    <!-- Бренд -->
    <div>
      <div class="flex items-center gap-2.5">
        <span
          class="grid h-8 w-8 place-items-center rounded-lg bg-[var(--color-accent)] text-sm font-bold text-white"
          aria-hidden="true">Б</span>
        <span class="font-[var(--font-display)] text-base font-semibold">{site.brand}</span>
      </div>
      <p class="mt-4 max-w-xs text-sm leading-relaxed text-[var(--color-muted)]">
        {site.brandTagline}. Небольшие группы, местный гид, живой лёд.
      </p>
      <p class="mt-3 text-sm text-[var(--color-muted)]">Иркутск · озеро Байкал</p>
    </div>

    <!-- Навигация -->
    <nav class="text-sm">
      <p class="font-medium">Разделы</p>
      <ul class="mt-3 space-y-2 text-[var(--color-muted)]">
        <li><a class="transition-colors hover:text-[var(--color-ink)]" href="#about">О нас</a></li>
        <li><a class="transition-colors hover:text-[var(--color-ink)]" href="#tours">Туры</a></li>
        <li><a class="transition-colors hover:text-[var(--color-ink)]" href="#how">Как всё устроено</a></li>
        <li><a class="transition-colors hover:text-[var(--color-ink)]" href="#faq">Вопросы</a></li>
      </ul>
    </nav>

    <!-- Контакт -->
    <div class="text-sm">
      <p class="font-medium">Связаться</p>
      <a
        href={site.telegram}
        target="_blank"
        rel="noopener"
        class="mt-3 inline-flex items-center gap-2 rounded-lg border border-[var(--color-line)] px-4 py-2 font-medium text-[var(--color-accent)] transition-colors hover:border-[var(--color-accent)] hover:bg-[var(--color-fill)]"
      >
        Telegram · {site.telegramHandle}
      </a>
      <p class="mt-3 text-[var(--color-muted)]">Отвечаем сами, обычно в течение дня.</p>
    </div>
  </div>

  <div class="container-page mt-12 border-t border-[var(--color-line)] pt-6 text-xs text-[var(--color-muted)]">
    <p>© {year} {site.brand} · Иркутск, озеро Байкал</p>
  </div>
</footer>
