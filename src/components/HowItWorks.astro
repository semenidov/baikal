---
import { howItWorks } from '../data/site';
---

<section id="how" class="py-14 sm:py-20 lg:py-28">
  <div class="container-page">
    <p class="eyebrow">{howItWorks.eyebrow}</p>
    <h2 class="mt-3 text-3xl sm:text-4xl">{howItWorks.title}</h2>

    <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {
        howItWorks.steps.map((step) => (
          <div class="rounded-2xl border border-[var(--color-line)] bg-[var(--color-surface)] p-6">
            <span class="font-[var(--font-display)] text-3xl font-semibold text-[var(--color-accent)]/30">
              {step.n}
            </span>
            <h3 class="mt-3 text-lg">{step.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-[var(--color-muted)]">{step.text}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
