---
import { trust } from '../data/site';
---

<section class="bg-[var(--color-accent-strong)] py-20 text-white sm:py-28">
  <div class="container-page">
    <p class="eyebrow text-[#9fd0e0]">{trust.eyebrow}</p>
    <h2 class="mt-3 text-3xl text-white sm:text-4xl">{trust.title}</h2>

    <div class="mt-12 grid gap-x-10 gap-y-8 sm:grid-cols-2">
      {
        trust.points.map((point) => (
          <div class="border-t border-white/20 pt-5">
            <h3 class="text-lg text-white">{point.title}</h3>
            <p class="mt-2 leading-relaxed text-[#d3e6ee]">{point.text}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
