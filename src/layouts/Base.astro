---
import '../styles/global.css';
import Analytics from '@vercel/analytics/astro';
import { site } from '../data/site';

interface Props {
  title?: string;
  description?: string;
}

const { title = site.meta.title, description = site.meta.description } = Astro.props;

// Абсолютные URL для мета-тегов (Astro.site задан в astro.config.mjs).
const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL('/og-image.jpg', Astro.site);

// Структурированные данные (Schema.org) — помогают Google понять, что это за
// сайт. Цену намеренно не указываем: по брифу цена «уточняется в переписке»,
// фиксированное число в разметке могло бы попасть в сниппет поиска и разойтись
// с тем, что говорим на самой странице.
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'TravelAgency',
  name: site.brand,
  url: String(Astro.site),
  logo: new URL('/icon-512.png', Astro.site).toString(),
  image: ogImage.toString(),
  description: site.meta.description,
  areaServed: {
    '@type': 'Place',
    name: 'озеро Байкал, Иркутская область',
  },
  sameAs: [site.telegram],
};
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- Предзагрузка критических шрифтов (кириллица) — меньше мигания на первой загрузке. -->
    <link
      rel="preload"
      href="/fonts/unbounded-cyrillic-600.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/inter-cyrillic-wght.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="theme-color" content="#1e6c88" />

    <!-- Open Graph (Telegram, VK, Facebook) -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={site.brand} />
    <meta property="og:locale" content="ru_RU" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Закат над льдом озера Байкал" />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/manifest.webmanifest" />

    <!-- Structured data: помогает Google/Яндексу распознать агентство. -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} is:inline />
  </head>
  <body>
    <slot />
    <Analytics />
    <!-- Считаем клики по Telegram как конверсию (с указанием секции). -->
    <script>
      import { track } from '@vercel/analytics';
      document.querySelectorAll('a[href*="t.me/"]').forEach((el) => {
        el.addEventListener('click', () => {
          const section = el.closest('[id]')?.id || 'header';
          track('telegram_click', { section });
        });
      });
    </script>
  </body>
</html>
